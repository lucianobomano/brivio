
model StandupUpdate {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  standup_id  String    @db.Uuid
  user_id     String    @db.Uuid
  content     Json      @default("[]") // Stores answers to questions
  mood        String?   // 'happy', 'neutral', 'bad'
  blockers    String?
  kudos       Int       @default(0)
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  updated_at  DateTime? @default(now()) @db.Timestamptz(6)

  standup     Standup   @relation(fields: [standup_id], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("standup_updates")
}
